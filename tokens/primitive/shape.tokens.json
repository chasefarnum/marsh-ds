{
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm":   { "$type": "dimension", "$value": "2px" },
    "md":   { "$type": "dimension", "$value": "4px" },
    "lg":   { "$type": "dimension", "$value": "6px" },
    "xl":   { "$type": "dimension", "$value": "8px" },
    "pill": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.05)"
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "4px",
        "blur": "12px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.08)"
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.10)"
      }
    }
  }
}
